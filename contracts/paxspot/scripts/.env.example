# PaxSpot Deployment Configuration
# Copy to .env and fill in values before deploying.

# Deployer private key (hex, no 0x prefix)
PRIVATE_KEY=

# Pyth oracle contract address on HyperPaxeer
PYTH_ADDRESS=0x0000000000000000000000000000000000000000

# Oracle staleness threshold in seconds (default: 60)
STALE_THRESHOLD=60

# Minimum VOM validator attestations (default: 1)
MIN_VOM_QUORUM=1

# Settlement epoch length in blocks (default: 5 = ~10s at 2s blocks)
EPOCH_LENGTH=5

# Treasury address for fast-settle fees (defaults to deployer)
# TREASURY=0x...

# Order cooldown in blocks per address (default: 3)
ORDER_COOLDOWN=3

# RPC URL
RPC_URL=http://127.0.0.1:8545
