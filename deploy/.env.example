# HyperPaxeer v19-paxspot — Validator Environment Configuration
# Copy to .env and fill in values before starting.

# REQUIRED: Validator's ETH private key (hex with 0x prefix)
# Export from existing node: evmosd keys unsafe-export-eth-key validator --keyring-backend test
VALIDATOR_ETH_KEY=0x_YOUR_VALIDATOR_ETH_PRIVATE_KEY_HERE

# Chain data directory (absolute path to your existing .evmosd data)
DATA_DIR=./data

# Price submitter interval in seconds (default: 20 = ~10 blocks at 2s/block)
PRICE_INTERVAL=20

# Set to "true" to log prices without submitting (testing mode)
DRY_RUN=false
